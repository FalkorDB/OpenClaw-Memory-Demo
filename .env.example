# OpenAI API key (required)
OPENAI_API_KEY=your-openai-api-key-here

# FalkorDB deployment mode: "docker" or "cloud"
FALKORDB_MODE=docker

# FalkorDB connection (defaults work for local Docker)
FALKORDB_HOST=localhost
FALKORDB_PORT=6379

# FalkorDB Cloud credentials (only needed when FALKORDB_MODE=cloud)
FALKORDB_USERNAME=default
FALKORDB_PASSWORD=
